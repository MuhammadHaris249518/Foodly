# ── Database (required) ───────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/foodly_db

# ── Security (required) ──────────────────────────────────────
SECRET_KEY=generate-a-strong-random-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ADMIN_SECRET=your-admin-secret-here

# ── AI APIs (required for AI features) ───────────────────────
GOOGLE_API_KEY=your-google-gemini-api-key
GROQ_API_KEY=your-groq-api-key
TAVILY_API_KEY=your-tavily-api-key

# ── Caching (optional — defaults to localhost) ───────────────
REDIS_URL=redis://localhost:6379/0

# ── Application ──────────────────────────────────────────────
PROJECT_NAME=Foodly
# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of exact origins allowed to make credentialed
# requests to this API. Include scheme + host + port, no trailing slash.
# Dev default (used if unset): http://localhost:3000,http://127.0.0.1:3000
ALLOWED_ORIGINS=http://localhost:3000,https://foodly.pk,https://www.foodly.pk
